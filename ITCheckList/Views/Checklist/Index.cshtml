@model List<ITCheckList.Models.TBL_CheckItem>
@{
    ViewData["Title"] = "لیست بررسی‌های روزانه";
}
<!-- اضافه کردن Font Awesome از CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<!--=================================================================-->
@{
    var successMessage = TempData["SuccessMessage"] as string;
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <script>
        // استفاده از Toastify برای نمایش پیام
        Toastify({
            text: "@successMessage",
            duration: 3000, // مدت زمان نمایش پیام (3 ثانیه)
            gravity: "top", // محل نمایش پیام (بالا)
            position: "right", // موقعیت پیام (راست)
            backgroundColor: "#4CAF50", // رنگ پس‌زمینه پیام (سبز برای موفقیت)
            close: true // اضافه کردن دکمه بستن
        }).showToast();
    </script>
}
<!--=================================================================-->
<div class="mt-5" id="reportSection" dir="rtl">
    <h4 class="text-center fw-bold">لیست بررسی‌های روزانه دپارتمان دپارتمان فناوری اطلاعات</h4>
    <!-- نوار ابزار بالا -->
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 my-3">
        <button id="btnAdd" type="button" class="btn custom-btn-success">
            افزودن موضوع جدید
        </button>
        <p class="mb-0">تاریخ امروز: <span class="fw-bold" id="shamsiDate"></span></p>
    </div>

    <!-- جدول اطلاعات -->
    <table class="table table-bordered text-center align-middle responsive-table" id="reportTable">
        <thead class="table-light">
            <tr>
                <th>ردیف</th>
                <th>بخش</th>
                <th>موضوع</th>
                <th>تاریخ</th>
                <th>توضیحات</th>
                <th>وضعیت</th>
                <th>عملیات</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                int i = 1;
                foreach (var item in Model)
                {
                    <tr>
                        <td>@(i++)</td>
                        <td class="text-end">@item.Section</td>
                        <td class="text-end">@item.Description</td>
                        <td>@item.CreatedAt.ToString("yyyy/MM/dd")</td>
                        <td class="text-end">@item.Note</td>
                        <td>
                            <span class="@(item.Status ? "status-done" : "status-pending")">
                                @(item.Status ? "انجام شد." : "در دست اقدام.")
                            </span>
                        </td>
                        <td class="text-center">
                            <!-- لینک ویرایش -->
                            <a asp-controller="Checklist" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                <i class="fas fa-edit fa-lg"></i>
                            </a>

                            <!-- دکمه حذف (همچنان با JS اگر نیاز باشه) -->
                            <button class="btn btn-sm btn-outline-danger btn-delete" data-id="@item.Id">
                                <i class="fas fa-trash-alt fa-lg"></i>
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    <!-- دکمه دریافت خروجی -->
    <div class="text-start mt-3">
        <!-- دکمه درج در بایگانی امروز -->
        <button class="btn custom-btn btn-outline-success" onclick="archiveTodayTasks()">درج در بایگانی امروز</button>
        <button class="btn custom-btn btn-outline-primary" onclick="printFullTable()">دریافت خروجی از اطلاعات</button>
    </div>

</div>
<!--=================================================================-->
<!--نمایش مودال جهت ثبت اطلاعات-->
<div class="modal fade" id="modalForm" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalLabel">ثبت بررسی جدید</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody" dir="rtl">
                <!-- فرم در اینجا بارگذاری می‌شود -->
            </div>
        </div>
    </div>
</div>
<!--=================================================================-->
@section ITCheckListPrint {
    <!--فراخوانی فایل اسکریپت آنلاین -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/print-js/1.6.0/print.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!--=================================================================-->
    <!--فراخوانی اسکریپت خروجی گزارش از اطلاعات-->
    <script src="~/lib/exporttableprint.js"></script>
    <!--=================================================================-->
    <script>
                function archiveTodayTasks() {
            // ارسال درخواست به سرور برای بایگانی کارهای امروز
            $.ajax({
                url: '/Checklist/ArchiveTodayTasks', // اکشن مربوطه
                type: 'POST',
                success: function(response) {
                    if (response.success) {
                        toastr.success('تمام کارهای امروز با موفقیت در بایگانی ذخیره شد.', 'عملیات موفقیت‌آمیز');
                    } else {
                        toastr.error('خطا در ذخیره‌سازی کارهای امروز. لطفاً دوباره تلاش کنید.', 'عملیات ناموفق');
                    }
                },
                error: function() {
                    toastr.error('خطا در ارسال درخواست. لطفاً دوباره تلاش کنید.', 'عملیات ناموفق');
                }
            });
        }

    </script>
    <!--=================================================================-->
    <script>
        $(document).ready(function () {
            // بررسی اینکه پیامی از TempData ارسال شده باشد
            var successMessage = '@TempData["SuccessMessage"]';
            if (successMessage) {
                // نمایش پیام ToastNotify با Toastr و رنگ سفارشی
                toastr.success(successMessage, 'عملیات موفقیت‌آمیز', {
                    timeOut: 1800,
                    closeButton: true,  // نمایش دکمه بستن
                    progressBar: true,  // نمایش نوار پیشرفت
                    positionClass: 'toast-top-center', // موقعیت نمایش
                    toastClass: 'custom-toast-success'  // اضافه کردن کلاس سفارشی
                });
            }
        });
    </script>
    <!--=================================================================-->
    <!--تبدیل تاریخ میلادی به شمسی-->
    <script>
        function toShamsi(gDate) {
            const g_y = gDate.getFullYear();
            const g_m = gDate.getMonth() + 1;
            const g_d = gDate.getDate();

            const g_days_in_month = [31,28,31,30,31,30,31,31,30,31,30,31];
            const j_days_in_month = [31,31,31,31,31,31,30,30,30,30,30,29];

            function div(a,b) {
                return Math.floor(a/b);
            }

            let gy = g_y - 1600;
            let gm = g_m - 1;
            let gd = g_d - 1;

            let g_day_no = 365*gy + div((gy+3),4) - div((gy+99),100) + div((gy+399),400);

            for (let i=0; i < gm; ++i)
                g_day_no += g_days_in_month[i];
            if (gm>1 && ((gy%4==0 && gy%100!=0) || (gy%400==0)))
                ++g_day_no;
            g_day_no += gd;

            let j_day_no = g_day_no - 79;

            let j_np = div(j_day_no, 12053);
            j_day_no %= 12053;

            let jy = 979 + 33*j_np + 4*div(j_day_no,1461);
            j_day_no %= 1461;

            if (j_day_no >= 366) {
                jy += div((j_day_no-1),365);
                j_day_no = (j_day_no-1)%365;
            }

            let jm, jd, i;
            for (i=0; i < 11 && j_day_no >= j_days_in_month[i]; ++i) {
                j_day_no -= j_days_in_month[i];
            }
            jm = i + 1;
            jd = j_day_no + 1;

            return {
                year: jy,
                month: jm.toString().padStart(2, '0'),
                day: jd.toString().padStart(2, '0')
            };
        }
        // روزهای هفته به فارسی
        const weekDays = [
            "یک‌شنبه",
            "دوشنبه",
            "سه‌شنبه",
            "چهارشنبه",
            "پنج‌شنبه",
            "جمعه",
            "شنبه"
        ];
        // درج تاریخ در span
        document.addEventListener("DOMContentLoaded", function () {
            const today = new Date();
            const shamsi = toShamsi(today);
            const weekDay = weekDays[today.getDay()];
            const formattedDate = `${weekDay} ${shamsi.year}/${shamsi.month}/${shamsi.day}`;
            document.getElementById("shamsiDate").innerText = formattedDate;
        });
    </script>
    <!--=================================================================-->
    <!--استایل های مربوط به جدول-->
    <style>
        .status-done {
            color: #44CA92;
            /* background-color: #f0fff9; */
            font-weight: bold;
        }

        .status-pending {
            color: #D80016;
            /* background-color: #ffe9eb; */
            font-weight: bold;
        }
    </style>
    <!--=================================================================-->
    <!--ثبت آیتم با نمایش SweetAlert-->
    <script>
        $(document).ready(function () {
            $('#btnAdd').click(function () {
                $.get('/Checklist/Create', function (data) {
                    $('#modalBody').html(data);
                    $('#modalForm').modal('show');
                });
            });

            $(document).on('submit', '#addChecklistForm', function (e) {
                e.preventDefault();
                $.ajax({
                    url: '/Checklist/Create',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (result) {
                        if (result.success) {
                            $('#modalForm').modal('hide');
                            Swal.fire("موفق!", result.message, "success").then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire("خطا", result.message, "error");
                        }
                    }
                });
            });
        });
    </script>
    <!--=================================================================-->
    <!--ویرایش آیتم با تأیید SweetAlert-->
    <script>
        $(document).ready(function () {
            // نمایش فرم ویرایش
            $(document).on("click", ".btn-edit", function () {
                const id = $(this).data("id");
                $.get("/Checklist/Edit/" + id, function (data) {
                    $("#modalBody").html(data);
                    $("#modalForm").modal("show");
                });
            });

        $(document).on("submit", "#editChecklistForm", function (e) {
            e.preventDefault();
            var formData = $(this).serialize();  // جمع‌آوری داده‌های فرم
            $.ajax({
                url: "/Checklist/Edit",  // آدرس درخواست
                type: "POST",
                data: formData,  // ارسال داده‌ها
                success: function (res) {
                    if (res.success) {
                        $("#modalForm").modal("hide");  // بستن مودال پس از موفقیت
                        Swal.fire("ویرایش شد!", res.message, "success").then(() => location.reload());
                    } else {
                        Swal.fire("خطا", res.message, "error");
                    }
                },
                error: function () {
                    Swal.fire("خطا", "خطا در ارسال درخواست!", "error");
                }
            });
        });
        });
    </script>
    <!--=================================================================-->
    <!--حذف آیتم با تأیید SweetAlert-->
    <script>
        $(document).on("click", ".btn-delete", function () {
            const id = $(this).data("id");
            Swal.fire({
                title: "آیا از حذف اطلاعات مطمئن هستید؟",
                text: ".بعد از حذف، اطلاعات قابل بازگشت نیست",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "بله، حذف کن",
                cancelButtonText: "انصراف"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post("/Checklist/Delete/" + id, function (res) {
                        if (res.success) {
                            Swal.fire("حذف شد", res.message, "success").then(() => location.reload());
                        } else {
                            Swal.fire("خطا", res.message, "error");
                        }
                    });
                }
            });
        });
    </script>
}