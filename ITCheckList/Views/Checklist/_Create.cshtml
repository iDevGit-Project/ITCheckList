@model ITCheckList.Models.TBL_CheckItem

<!-- فرم افزودن موضوع جدید -->
<form id="addChecklistForm" dir="rtl">
    <div class="mb-3">
        <label for="section" class="form-label fw-bold">نام بخش</label>
        <input type="text" name="Section" class="form-control" id="section" required />
        <span asp-validation-for="Section" class="text-danger small fw-bold"></span>
    </div>

    <div class="mb-3">
        <label for="description" class="form-label fw-bold">توضیحات</label>
        <input type="text" name="Description" class="form-control" id="description" required />
        <span asp-validation-for="Description" class="text-danger small fw-bold"></span>
    </div>

    <div class="mb-3">
        <label for="status" class="form-label fw-bold">وضعیت</label>
        <select name="Status" id="status" class="form-select" required>
            <option value="">-- انتخاب وضعیت --</option>
            <option value="false">در دست بررسی</option>
            <option value="false">در دست اقدام</option>
            <option value="true">انجام شد</option>
        </select>
        <span asp-validation-for="Status" class="text-danger small fw-bold"></span>
    </div>

    <div class="mb-3">
        <label for="note" class="form-label fw-bold">ثبت یادداشت</label>
        <input type="text" name="Note" class="form-control" id="note" />
        <span asp-validation-for="Note" class="text-danger small fw-bold"></span>
    </div>

    <button type="submit" class="btn btn-success px-4">ثبت اطلاعات</button>
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">بستن</button>
</form>

@section ValidationAddCheckListForm {
        // بررسی کردن مقادیر درون ورودی ها
    <partial name="_ValidationScriptsPartial" />
}