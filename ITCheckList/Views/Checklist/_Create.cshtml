@model ITCheckList.Models.TBL_CheckItem

<!-- فرم افزودن موضوع جدید -->
<form id="addChecklistForm">
    <div class="form-group">
        <label for="section">بخش</label>
        <input type="text" name="Section" class="form-control" id="section" required />
    </div>
    <div class="form-group">
        <label for="description">توضیحات</label>
        <input type="text" name="Description" class="form-control" id="description" required />
    </div>
    <div class="form-check">
        <input type="checkbox" name="Status" class="form-check-input" id="status" />
        <label class="form-check-label" for="status">تأیید شده</label>
    </div>
    <div class="form-group">
        <label for="note">یادداشت</label>
        <input type="text" name="Note" class="form-control" id="note" />
    </div>
    <button type="submit" class="btn btn-success">ثبت اطلاعات</button>
</form>
